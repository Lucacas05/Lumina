---
import PixelButton from "@/components/PixelButton.astro";
import PixelCard from "@/components/PixelCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteContent } from "@/data/site";
import { ICONS } from "@/lib/icons";

const { chronicles } = siteContent;
const accentClasses = {
  primary: "bg-primary border-primary text-on-primary",
  secondary: "bg-secondary border-secondary text-on-secondary",
  tertiary: "bg-tertiary border-tertiary text-on-tertiary",
} as const;
---

<BaseLayout title="Crónicas" currentPath="/cronicas">
  <div class="max-w-7xl mx-auto space-y-8 pb-8">
    <section class="relative overflow-hidden bg-surface-container-low pixel-border">
      <div class="absolute inset-0 dither-bg opacity-[0.15]" />
      <div class="absolute top-0 right-0 w-56 h-56 rounded-full bg-primary/10 blur-3xl" />

      <div class="relative p-8 md:p-10 flex flex-col lg:flex-row gap-8 lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-3 bg-secondary-container px-3 py-2 border-l-4 border-primary mb-5">
            <ICONS.History size={16} className="text-primary" />
            <span class="text-primary-fixed font-headline font-bold text-xs uppercase tracking-[0.2em]">
              {chronicles.badge}
            </span>
          </div>

          <h1 class="text-4xl md:text-6xl font-headline font-black text-on-surface uppercase tracking-tighter leading-none">
            {chronicles.title}
          </h1>
          <p class="mt-4 max-w-2xl text-on-surface-variant text-base md:text-lg leading-relaxed">
            {chronicles.description}
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <PixelButton href="/estudio" icon="BookOpen">{chronicles.resumeCta}</PixelButton>
          <PixelButton href="/refinar" variant="tertiary" icon="Users">{chronicles.visitCta}</PixelButton>
        </div>
      </div>
    </section>

    <section>
      <div class="flex items-center justify-between mb-6 gap-4">
        <h2 class="text-3xl font-headline font-black text-tertiary uppercase tracking-tighter flex items-center gap-3">
          <span class="w-8 h-8 bg-tertiary-container border-2 border-tertiary flex items-center justify-center">
            <ICONS.History size={16} className="text-tertiary" />
          </span>
          {chronicles.timelineTitle}
        </h2>
        <div class="hidden md:block h-1 flex-1 dither-bg opacity-20" />
        <span class="text-[10px] font-headline font-bold uppercase tracking-[0.25em] text-outline">
          {chronicles.timelineHint}
        </span>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
        <div class="xl:col-span-8">
          <PixelCard variant="high" class="overflow-hidden">
            <div class="space-y-0">
              {chronicles.sessions.map((session, index) => (
                <div class:list={["grid grid-cols-[auto_1fr] gap-4 md:gap-6", index < chronicles.sessions.length - 1 ? "pb-6 mb-6 border-b border-outline-variant/40" : ""]}>
                  <div class="flex flex-col items-center">
                    <div class:list={["w-12 h-12 border-4 flex items-center justify-center", accentClasses[session.accent]]}>
                      <ICONS.History size={18} />
                    </div>
                    {index < chronicles.sessions.length - 1 && <div class="w-1 flex-1 bg-outline-variant/70 min-h-16 mt-2" />}
                  </div>

                  <div class="pt-1">
                    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
                      <div>
                        <p class="text-[10px] font-headline font-bold uppercase tracking-[0.25em] text-outline">
                          {session.date}
                        </p>
                        <h3 class="text-xl font-headline font-black uppercase tracking-tight text-on-surface mt-1">
                          {session.title}
                        </h3>
                      </div>

                      <div class="grid grid-cols-2 gap-3 min-w-[220px]">
                        <div class="bg-surface-container-low px-3 py-2 border-b-4 border-primary">
                          <p class="text-[10px] font-headline font-bold uppercase tracking-widest text-outline">Duración</p>
                          <p class="text-sm font-headline font-black text-primary">{session.duration}</p>
                        </div>
                        <div class="bg-surface-container-low px-3 py-2 border-b-4 border-tertiary">
                          <p class="text-[10px] font-headline font-bold uppercase tracking-widest text-outline">Lectura</p>
                          <p class="text-sm font-headline font-black text-tertiary">{session.chapters}</p>
                        </div>
                      </div>
                    </div>

                    <p class="mt-4 text-sm text-on-surface-variant leading-relaxed">{session.note}</p>
                  </div>
                </div>
              ))}
            </div>
          </PixelCard>
        </div>

        <div class="xl:col-span-4">
          <PixelCard
            title={chronicles.cadenceTitle}
            subtitle={chronicles.cadenceSubtitle}
            variant="default"
            class="h-full"
            namePlate={chronicles.cadenceNamePlate}
          >
            <div class="space-y-5">
              {chronicles.cadence.map((entry) => (
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-headline font-bold uppercase tracking-widest text-on-surface">{entry.label}</span>
                    <span class="text-xs font-headline font-black text-outline">{entry.value}</span>
                  </div>
                  <div class="h-4 bg-surface-container-highest overflow-hidden">
                    <div class:list={["h-full", entry.width, entry.tone]}></div>
                  </div>
                </div>
              ))}
            </div>
          </PixelCard>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <div class="lg:col-span-7">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {chronicles.stats.map((stat) => {
            const Icon = ICONS[stat.icon];
            return (
              <div class:list={["bg-surface-container-high p-6 border-b-4 pixel-border", stat.tone]}>
                <div class="flex items-start justify-between gap-6">
                  <div>
                    <p class="text-[10px] font-headline font-bold uppercase tracking-[0.25em] text-outline">{stat.label}</p>
                    <p class="text-4xl font-headline font-black uppercase tracking-tight mt-3">{stat.value}</p>
                    <p class="text-sm text-on-surface-variant mt-3 leading-relaxed">{stat.detail}</p>
                  </div>
                  <div class="w-12 h-12 bg-surface-container-low flex items-center justify-center border-2 border-current/40 shrink-0">
                    <Icon size={22} />
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <div class="lg:col-span-5">
        <PixelCard title={chronicles.milestonesTitle} variant="highest" class="h-full">
          <div class="space-y-4">
            {chronicles.milestones.map((milestone) => {
              const Icon = ICONS[milestone.icon];
              return (
                <div class="bg-surface-container-low p-4 border border-outline-variant/40">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex items-start gap-3">
                      <div class="w-10 h-10 bg-surface-container-highest border-2 border-primary/30 flex items-center justify-center shrink-0">
                        <Icon size={18} className="text-primary" />
                      </div>
                      <div>
                        <h3 class="font-headline font-black uppercase tracking-tight text-on-surface">{milestone.title}</h3>
                        <p class="text-sm text-on-surface-variant mt-2 leading-relaxed">{milestone.description}</p>
                      </div>
                    </div>
                    <span class:list={["px-3 py-1 text-[10px] font-headline font-bold uppercase tracking-[0.18em] shrink-0", milestone.ribbonClass]}>
                      {milestone.ribbon}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </PixelCard>
      </div>
    </section>
  </div>
</BaseLayout>
